   "source": [
    "class Flyable:\n",
    "    def fly(self):\n",
    "        print(\"Flying in the sky\")\n",
    "\n",
    "class Swimmable:\n",
    "    def swim(self):\n",
    "        print(\"Swimming in water\")\n",
    "\n",
    "class Duck(Flyable, Swimmable):\n",
    "    pass\n",
    "\n",
    "# Example\n",
    "d = Duck()\n",
    "d.fly()\n",
    "d.swim()"
   ]
  }
